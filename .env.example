# ==================== CONFIGURACIÓN DE BASE DE DATOS ====================
# ⚠️ IMPORTANTE: Copia este archivo a .env y configura con TUS datos
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=ferreteria_db

# ==================== CONFIGURACIÓN DE EMAIL (SMTP) ====================
# ⚠️ NUNCA subas el archivo .env a git (ya está en .gitignore)
# ⚠️ Cada desarrollador debe crear su propio .env con SUS credenciales

# Proveedor: gmail, sendgrid, mailgun, brevo, smtp personalizado
MAIL_PROVIDER=gmail

# Configuración SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=tu-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Configuración del remitente
MAIL_FROM_ADDRESS=tu-email@gmail.com
MAIL_FROM_NAME=Ferretería El Tornillo

# ==================== PROVEEDORES POPULARES ====================
# 
# GMAIL:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USERNAME=tu-email@gmail.com
# SMTP_PASSWORD=contraseña-de-aplicacion (genera en: https://myaccount.google.com/apppasswords)
# Límite: 500 emails/día
#
# SENDGRID:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=tu-api-key
# Límite: 100 emails/día (gratis)
#
# BREVO (Sendinblue):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USERNAME=tu-email@gmail.com
# SMTP_PASSWORD=tu-api-key
# Límite: 300 emails/día (gratis)
#
# MAILGUN:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USERNAME=postmaster@tu-dominio.mailgun.org
# SMTP_PASSWORD=tu-contraseña
# Límite: 100 emails/día primeros 3 meses (gratis)
#
# OUTLOOK/HOTMAIL:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=tls
# SMTP_USERNAME=tu-email@outlook.com
# SMTP_PASSWORD=tu-contraseña
#
